{
  "version": 2,
  "builds": [
    {
      "src": "datasub/wsgi.py",
      "use": "@vercel/python",
      "config": { 
        "maxLambdaSize": "15mb", 
        "runtime": "python3.11",
        "maxDuration": 10
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "datasub/wsgi.py"
    }
  ]
}