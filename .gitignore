# Compiled Python files (These change every time you run the server)
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments (This contains thousands of library files you don't need to push)
venv/
ENV/

# Sensitive Information (Never push your API keys or Secret Keys!)
.env
.env.bak

# Local Database (Pushing this can overwrite your group members' local data)
db.sqlite3

# Folder metadata
.vscode/
.idea/

# SSL Certificates (STRICTLY PRIVATE)
cert.crt
cert.key

# Security & Audit Logs
logs/
*.log
SECURITY_REPORT_2026.md
SECURITY_AUDIT_COMPLETE.md
SECURITY_FIXES_IMPLEMENTED.md
